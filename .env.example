# ==========================================
# RSS Aggregator v2.10 - Configuration Template
# ==========================================
# Copy this file to .env and fill in your own values!
# NEVER commit real credentials to version control!
# 
# For more info, see README.md

# Telegram Bot Token (required)
# Generate at: https://t.me/botfather
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"

# Your Telegram Channel ID or Group Chat ID (required)
# -100 for channels/groups, regular number for personal chats
# Find it using: python3 /home/mitch/projects/sandboxes/news_aggregator/find_chat_id.py
TELEGRAM_CHAT_ID="-100xxxxxxxxx"  # Example: -100123456789 or 123456789

# Telegram API Rate Limiting (seconds between sends)
RATE_LIMIT_SEC=30

# Debug Mode (set to true for test mode)
DEBUG_MODE=false

# Force refresh of dedup tracker (true = send everything, false = skip duplicates)
FORCE_REFRESH=false

# Run at 8 AM only (cron job trigger simulation)
RUN_AS_8AM=true

# ==========================================
# RSS Feed Configuration
# ==========================================
# These are configured in the aggregator's config.py or settings files
# NOT in .env - they're hardcoded or use separate config management

# ==========================================
# Security Notes
# ==========================================
# 1. Never commit real values to .env file
# 2. Always copy from .env.example to .env locally
# 3. Use .gitignore to prevent accidental commits
# 4. Consider using GitHub Secrets for production deployments
