# Python bytecode (compiled)
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment variables - NEVER commit real .env files!
.env
.env.local
.env.*.local
!.env.example  # Allow example file for reference
!README.md

# Logs
*.log

# IDE / Editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Runtime trackers (optional - comment out if you want to track them)
dedup_tracker.json  # Or whatever your tracker is named
